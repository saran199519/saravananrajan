<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Saravanan Shanmuga Rajan — Learning Experience Expert</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --sand: #F5F0E8;
    --sand-mid: #EDE5D4;
    --sand-dark: #D9CEBC;
    --clay: #C4854A;
    --clay-light: #F0DEC8;
    --clay-dark: #8B5A2B;
    --bark: #3D2B1F;
    --bark-mid: #6B4C35;
    --bark-light: #9C7A5E;
    --moss: #5C6B4A;
    --moss-light: #E8EDE2;
    --cream: #FDFAF5;
    --text-primary: #2C1F14;
    --text-secondary: #6B4C35;
    --text-muted: #9C8070;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--text-primary);
    font-size: 16px;
    line-height: 1.7;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--cream);
    border-bottom: 1px solid var(--sand-dark);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .nav-logo {
    font-family: 'Lora', serif;
    font-size: 18px;
    font-weight: 600;
    color: var(--bark);
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }
  .nav-links a {
    font-size: 14px;
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 400;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--clay); }

  /* HERO */
  .hero {
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding: 6rem 2rem 4rem;
    max-width: 1100px;
    margin: 0 auto;
    gap: 4rem;
  }
  .hero-text { flex: 1; }
  .hero-tag {
    display: inline-block;
    background: var(--clay-light);
    color: var(--clay-dark);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }
  .hero h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 600;
    line-height: 1.15;
    color: var(--bark);
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--clay);
  }
  .hero-sub {
    font-size: 17px;
    color: var(--text-secondary);
    max-width: 520px;
    margin-bottom: 2.5rem;
    line-height: 1.75;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--clay);
    color: #fff;
    padding: 12px 28px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: var(--clay-dark); transform: translateY(-1px); }
  .btn-outline {
    background: transparent;
    color: var(--bark);
    padding: 12px 28px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 400;
    border: 1.5px solid var(--sand-dark);
    transition: border-color 0.2s, transform 0.15s;
  }
  .btn-outline:hover { border-color: var(--clay); color: var(--clay); transform: translateY(-1px); }

  .hero-visual {
    flex: 0 0 340px;
    background: var(--sand);
    border-radius: 20px;
    padding: 2.5rem;
    border: 1px solid var(--sand-dark);
  }
  .hero-initials {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--clay-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Lora', serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--clay-dark);
    margin-bottom: 1.25rem;
  }
  .hero-visual h3 {
    font-family: 'Lora', serif;
    font-size: 18px;
    color: var(--bark);
    margin-bottom: 4px;
  }
  .hero-visual p {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .pill {
    background: var(--cream);
    border: 1px solid var(--sand-dark);
    color: var(--bark-mid);
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 100px;
  }
  .award-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sand-dark);
    font-size: 13px;
    color: var(--text-secondary);
  }
  .award-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--clay);
    flex-shrink: 0;
    margin-top: 5px;
  }

  /* SECTION WRAPPER */
  section { padding: 5rem 2rem; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clay);
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: 'Lora', serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 600;
    color: var(--bark);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .section-desc {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 580px;
    margin-bottom: 3rem;
  }

  /* IMPACT METRICS */
  .metrics-section { background: var(--sand); }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .metric-card {
    background: var(--cream);
    border: 1px solid var(--sand-dark);
    border-radius: 16px;
    padding: 1.75rem;
  }
  .metric-number {
    font-family: 'Lora', serif;
    font-size: 2.6rem;
    font-weight: 600;
    color: var(--clay);
    line-height: 1;
    margin-bottom: 6px;
  }
  .metric-label {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.4;
  }
  .metric-context {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 4px;
  }

  /* WHAT I DO */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .service-card {
    background: var(--sand);
    border: 1px solid var(--sand-dark);
    border-radius: 16px;
    padding: 2rem;
    transition: border-color 0.2s;
  }
  .service-card:hover { border-color: var(--clay); }
  .service-icon {
    width: 44px;
    height: 44px;
    background: var(--clay-light);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    font-size: 20px;
  }
  .service-card h3 {
    font-family: 'Lora', serif;
    font-size: 17px;
    color: var(--bark);
    margin-bottom: 0.5rem;
  }
  .service-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* CASE STUDIES */
  .case-studies-section { background: var(--sand); }
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .case-card {
    background: var(--cream);
    border: 1px solid var(--sand-dark);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
  }
  .case-card:hover { transform: translateY(-3px); border-color: var(--clay); }
  .case-card-img {
    height: 160px;
    background: var(--clay-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
  }
  .case-card-body { padding: 1.5rem; }
  .case-tag {
    display: inline-block;
    background: var(--moss-light);
    color: var(--moss);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 100px;
    margin-bottom: 0.75rem;
  }
  .case-card h3 {
    font-family: 'Lora', serif;
    font-size: 17px;
    color: var(--bark);
    margin-bottom: 0.5rem;
  }
  .case-card p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .case-result {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: var(--clay-dark);
  }
  .case-result-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--clay);
    flex-shrink: 0;
  }

  /* TIMELINE / EXPERIENCE */
  .timeline { margin-top: 2.5rem; position: relative; }
  .timeline::before {
    content: '';
    position: absolute;
    left: 18px;
    top: 8px;
    bottom: 8px;
    width: 1.5px;
    background: var(--sand-dark);
  }
  .timeline-item {
    display: flex;
    gap: 2rem;
    margin-bottom: 2.5rem;
    position: relative;
  }
  .timeline-dot {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--clay-light);
    border: 2px solid var(--clay);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    z-index: 1;
  }
  .timeline-content { flex: 1; padding-top: 6px; }
  .timeline-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
    flex-wrap: wrap;
  }
  .timeline-period {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 400;
  }
  .timeline-company {
    font-size: 12px;
    font-weight: 500;
    color: var(--clay-dark);
    background: var(--clay-light);
    padding: 2px 10px;
    border-radius: 100px;
  }
  .timeline-role {
    font-family: 'Lora', serif;
    font-size: 17px;
    color: var(--bark);
    margin-bottom: 0.5rem;
  }
  .timeline-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
  }
  .timeline-highlights {
    list-style: none;
    margin-top: 0.75rem;
  }
  .timeline-highlights li {
    font-size: 13px;
    color: var(--text-secondary);
    padding: 3px 0;
    padding-left: 16px;
    position: relative;
  }
  .timeline-highlights li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--clay);
    font-size: 11px;
    top: 4px;
  }

  /* TOOLS */
  .tools-section { background: var(--sand); }
  .tools-groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .tools-group {
    background: var(--cream);
    border: 1px solid var(--sand-dark);
    border-radius: 14px;
    padding: 1.5rem;
  }
  .tools-group-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--clay-dark);
    margin-bottom: 1rem;
  }
  .tools-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tool-tag {
    background: var(--sand);
    border: 1px solid var(--sand-dark);
    color: var(--bark-mid);
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 100px;
  }

  /* AWARDS */
  .awards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }
  .award-card {
    background: var(--sand);
    border: 1px solid var(--sand-dark);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .award-icon {
    font-size: 22px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .award-title {
    font-size: 14px;
    font-weight: 500;
    color: var(--bark);
    margin-bottom: 2px;
  }
  .award-org {
    font-size: 12px;
    color: var(--text-muted);
  }

  /* CONTACT */
  .contact-section {
    background: var(--bark);
    color: var(--cream);
  }
  .contact-section .section-label { color: var(--clay-light); }
  .contact-section .section-title { color: var(--cream); }
  .contact-section .section-desc { color: var(--sand); }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 2.5rem;
  }
  .contact-item {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 1.25rem;
  }
  .contact-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .contact-item-text { font-size: 14px; }
  .contact-item-label { font-size: 11px; color: var(--bark-light); margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.08em; }
  .contact-item a { color: var(--sand); text-decoration: none; }
  .contact-item a:hover { color: var(--clay-light); }
  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: #a8d5b5;
    font-size: 13px;
    padding: 8px 16px;
    border-radius: 100px;
    margin-bottom: 2rem;
  }
  .avail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #6dbf85;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* FOOTER */
  footer {
    background: var(--bark);
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 1.5rem 2rem;
    text-align: center;
    font-size: 13px;
    color: var(--bark-light);
  }

  /* DIVIDER */
  .divider {
    height: 1px;
    background: var(--sand-dark);
    max-width: 1100px;
    margin: 0 auto;
  }

  /* COMPANIES */
  .companies-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
    align-items: center;
  }
  .company-badge {
    background: var(--sand);
    border: 1px solid var(--sand-dark);
    color: var(--bark-mid);
    font-size: 13px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: 100px;
  }

  @media (max-width: 768px) {
    .hero { flex-direction: column; padding: 4rem 1.5rem 3rem; gap: 2.5rem; }
    .hero-visual { flex: unset; width: 100%; }
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    nav { padding: 0 1.25rem; }
    .nav-links { gap: 1rem; }
    section { padding: 3.5rem 1.25rem; }
  }
</style>
</head>
